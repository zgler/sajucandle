# Phase 5 transport (관리자 1명 Telegram 전송)
#
# 로컬 설정:
#   cp .env.example .env
# 1. BotFather(@BotFather)에서 봇 생성 → TELEGRAM_BOT_TOKEN 획득
# 2. 본인 Telegram에서 @userinfobot 에게 메시지 → 본인 chat_id 확인
# 3. TRANSPORT_ENABLED=true 로 설정 후 `--date YYYY-MM-DD` 로 테스트 실행
#
# 배포 환경(Railway 등)은 Dashboard에서 동일 키 주입.

TRANSPORT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
